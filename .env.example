# Supabase — Project Settings → API (required for frontend / Vercel)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Maps Geocoding (optional — admin address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=

# Secret key (server-side only — never expose in frontend builds)
# Dashboard → Settings → API Keys → Secret keys → Copy
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Database connection URI (required for npm run setup:db migrations)
# Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
